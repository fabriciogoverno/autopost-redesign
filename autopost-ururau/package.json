{
  "name": "autopost-ururau",
  "version": "1.0.0",
  "description": "Sistema autônomo de geração e publicação automática de posts para redes sociais — Projeto Ururau",
  "main": "src/backend/api/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/backend/api/server.js",
    "cli": "node src/backend/cli/autopost.js",
    "dashboard": "cd src/dashboard && npm run dev",
    "test": "node test-runner.js",
    "db:init": "node src/backend/core/database.js --init",
    "db:migrate": "node src/backend/core/database.js --migrate",
    "autoblog": "node src/backend/cli/autopost.js autoblog-run",
    "test:generate": "node test-generate.js",
    "generate": "node src/backend/cli/autopost.js generate",
    "test:caption": "node test-caption.js",
    "caption": "node src/backend/cli/autopost.js caption-test",
    "test:publisher": "node test-publisher.js",
    "publish": "node src/backend/cli/autopost.js publish",
    "test:connection": "node src/backend/cli/autopost.js test-connection",
    "test:autoblog": "node test-autoblog.js",
    "autoblog:start": "node src/backend/cli/autopost.js autoblog-start",
    "schedule": "node src/backend/cli/autopost.js schedule",
    "schedule:list": "node src/backend/cli/autopost.js schedule-list",
    "server": "node src/backend/api/server.js --start",
    "rollback": "node src/backend/cli/autopost.js rollback",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "test:e2e": "node --test tests/e2e/*.test.js",
    "test:hash": "node --test tests/unit/hash.test.js",
    "test:db": "node --test tests/unit/database.test.js",
    "setup": "node setup.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "sharp": "^0.33.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "node-cron": "^3.0.3",
    "commander": "^11.1.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "dotenv": "^16.3.1",
    "axios": "^1.6.2",
    "form-data": "^4.0.0",
    "puppeteer": "^21.6.1",
    "twitter-api-v2": "^1.15.2",
    "whatsapp-web.js": "^1.23.0",
    "qrcode-terminal": "^0.12.0",
    "node-fetch": "^3.3.2",
    "sqlite3": "^5.1.6",
    "sqlite": "^5.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "autopost",
    "ururau",
    "automação",
    "redes-sociais",
    "whatsapp",
    "instagram",
    "jornalismo"
  ],
  "author": "fabri — Projeto Ururau",
  "license": "MIT"
}